<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_gradient"
    android:padding="32dp">

    <!-- Иконка -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌐"
        android:textSize="72sp"
        android:layout_marginBottom="24dp" />

    <!-- Заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_online_pvp"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Статус -->
    <TextView
        android:id="@+id/matchmaking_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/matchmaking_searching"
        android:textColor="#B0A0C0"
        android:textSize="16sp"
        android:layout_marginBottom="40dp" />

    <!-- Индикатор загрузки -->
    <ProgressBar
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:indeterminate="true"
        android:indeterminateTint="#8F5CFF"
        android:layout_marginBottom="40dp" />

    <!-- Таймер -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/matchmaking_waiting"
        android:textColor="#55FFFFFF"
        android:textSize="13sp"
        android:layout_marginBottom="48dp" />

    <!-- Кнопка отмены -->
    <Button
        android:id="@+id/btn_cancel_matchmaking"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:text="@string/btn_cancel"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#44FFFFFF"
        android:stateListAnimator="@null" />

</LinearLayout>
