<?xml version="1.0" encoding="utf-8"?>
<!--
  App icon foreground: basketball hoop ring with "MARS" label on the rim.
  Adaptive icon safe-zone is the inner 72×72 box starting at (18,18).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Outer ring glow (shadow/halo) ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#BF7B2FFF"
        android:strokeWidth="6"
        android:pathData="M54,28 A26,26 0 1,1 53.999,28 Z"/>

    <!-- ── Main rim ring — orange thick torus ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF6D00"
        android:strokeWidth="10"
        android:pathData="M54,28 A26,26 0 1,1 53.999,28 Z"/>

    <!-- ── Rim highlight arc (top-left shine) ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFAB40"
        android:strokeWidth="4"
        android:pathData="M35,40 A20,20 0 0,1 73,40"/>

    <!-- ── Net — 7 converging vertical strings ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#DDDDDD"
        android:strokeWidth="1.6"
        android:pathData="M38,53 L36,72
                          M43,54 L42,72
                          M48,54 L48,73
                          M54,54 L54,73
                          M60,54 L60,73
                          M65,54 L66,72
                          M70,53 L72,72"/>

    <!-- ── Net — horizontal weave bands ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#DDDDDD"
        android:strokeWidth="1.4"
        android:pathData="M37,62 Q54,58 71,62
                          M36,72 Q54,69 72,72"/>

    <!-- ── Net bottom closing arc ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#CCCCCC"
        android:strokeWidth="1.8"
        android:pathData="M36,72 Q54,78 72,72"/>

    <!-- ── "MARS" text on the rim ──
         Each letter is a simple path drawn along the top of the ring.
         Letters are spaced around the arc at y≈29, x-offsets for each.
    -->
    <!-- M -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M29,33 L29,26 L32,30 L35,26 L35,33"/>
    <!-- A -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,33 L40.5,26 L43,33 M38.8,30.5 L42.2,30.5"/>
    <!-- R -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,33 L46,26 L49,26 Q51,26 51,28.5 Q51,31 49,31 L46,31 M49,31 L51,33"/>
    <!-- S -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,26 Q57,26 57,28 Q57,30 54,30 Q57,30 57,32 Q57,34 54,34"/>

</vector>
